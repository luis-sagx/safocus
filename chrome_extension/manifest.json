{
  "manifest_version": 3,
  "name": "SaFocus — Bloqueador de Distracciones",
  "version": "1.0.0",
  "description": "Bloquea sitios web distractores. Mantén el enfoque.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs",
    "webNavigation",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    }
  },
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "default_block_rules",
        "enabled": true,
        "path": "rules/default_block_rules.json"
      },
      {
        "id": "user_block_rules",
        "enabled": false,
        "path": "rules/user_block_rules.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
